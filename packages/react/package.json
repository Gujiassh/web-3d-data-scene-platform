{
  "name": "@web3d/react",
  "version": "0.1.0-rc.1",
  "description": "React lifecycle and imperative API wrappers for @web3d/runtime.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gujiassh/web-3d-data-scene-platform.git",
    "directory": "packages/react"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publishConfig": {
    "access": "public",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "vite build --config vite.config.ts && tsc -p tsconfig.build.json && node ../../scripts/release/rewrite-declaration-imports.mjs dist",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@web3d/document": "workspace:*",
    "@web3d/runtime": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
