{
  "name": "web-3d-data-scene-platform",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "bench:light-006b": "node --experimental-strip-types benchmarks/006b-light-performance/run.mts",
    "bench:release-009": "node --experimental-strip-types benchmarks/009-release-performance/run.mts",
    "bench:hotspot-007": "node --experimental-strip-types benchmarks/007-hotspot-calibration/run.mts",
    "bench:smart-align": "node --experimental-strip-types benchmarks/smart-align-500.mts",
    "build": "pnpm -r --if-present build",
    "build:packages": "pnpm --filter @web3d/document --filter @web3d/runtime --filter @web3d/react --filter @web3d/publish build",
    "dev": "pnpm --filter @web3d/studio dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:contracts": "node packages/document/scripts/generate-validators.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test --workers=1",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tests/e2e/tsconfig.json && pnpm -r --if-present typecheck",
    "verify:design": "./scripts/verify-product-design.sh",
    "verify:docs": "vitest run scripts/release/docs-audit.test.mjs && node scripts/release/verify-docs.mjs",
    "verify:i18n": "node scripts/verify-i18n-copy.mjs",
    "verify:assets": "vitest run scripts/release/asset-audit.test.mjs && node scripts/release/verify-assets.mjs",
    "verify:packages": "node scripts/release/verify-packages.mjs",
    "verify:smart-home": "vitest run --config scripts/smart-home/vitest.config.mjs",
    "verify:topology": "node scripts/verify-topology.mjs"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.1",
    "@types/pngjs": "6.0.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "fake-indexeddb": "6.2.5",
    "fflate": "0.8.3",
    "gltf-validator": "2.0.0-dev.3.10",
    "pngjs": "7.0.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
