{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://web3d.example/schemas/publish-manifest-1.0.schema.json",
  "title": "Web3D Publish Manifest 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "publishVersion",
    "sceneSchemaVersion",
    "documentId",
    "revision",
    "entry",
    "files",
    "requirements"
  ],
  "properties": {
    "publishVersion": { "const": "1.0.0" },
    "sceneSchemaVersion": { "const": "1.4.0" },
    "documentId": { "type": "string", "minLength": 1 },
    "revision": { "type": "integer", "minimum": 0 },
    "entry": { "const": "scene.json" },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 127,
      "items": { "$ref": "#/$defs/file" }
    },
    "requirements": { "$ref": "#/$defs/requirements" }
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "byteLength", "mediaType"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-][A-Za-z0-9._/-]*$"
        },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "byteLength": { "type": "integer", "minimum": 1, "maximum": 52428800 },
        "mediaType": {
          "enum": ["application/json", "model/gltf-binary", "model/gltf+json"]
        }
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dataSources", "trustedContentKeys"],
      "properties": {
        "dataSources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sourceId", "adapter"],
            "properties": {
              "sourceId": { "type": "string", "minLength": 1 },
              "adapter": { "enum": ["mock", "websocket"] }
            }
          }
        },
        "trustedContentKeys": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
