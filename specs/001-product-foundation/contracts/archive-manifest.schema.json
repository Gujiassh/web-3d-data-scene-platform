{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/web-3d-data-scene/archive-manifest.schema.json",
  "title": "Web 3D Data Scene Archive Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["archiveVersion", "createdAt", "entry", "sceneSchemaVersion", "files"],
  "properties": {
    "archiveVersion": {
      "const": "1.0.0"
    },
    "createdAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "entry": {
      "const": "scene.json"
    },
    "sceneSchemaVersion": {
      "enum": ["1.0.0", "1.1.0"]
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/file"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "safePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9._-][A-Za-z0-9._/-]*$",
      "allOf": [
        {
          "not": {
            "pattern": "(^|/)\\.\\.(/|$)"
          }
        },
        {
          "not": {
            "pattern": "(^|/)\\.(/|$)"
          }
        },
        {
          "not": {
            "pattern": "//"
          }
        }
      ]
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "byteLength", "mediaType"],
      "properties": {
        "path": {
          "$ref": "#/$defs/safePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "byteLength": {
          "type": "integer",
          "minimum": 1
        },
        "mediaType": {
          "enum": ["application/json", "model/gltf-binary", "model/gltf+json"]
        }
      }
    }
  }
}
